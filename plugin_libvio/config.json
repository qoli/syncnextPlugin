      "url": "https://libvio.site/type/2-${pageNumber}.html",
      "javascript": "buildMedias"
    },
    {
      "key": "anime",
      "title": "动漫",
      "url": "https://libvio.site/type/4-${pageNumber}.html",
      "javascript": "buildMedias"
    },
    {
      "key": "jpandkr",
      "title": "日韩剧",
      "url": "https://libvio.site/type/15-${pageNumber}.html",
      "javascript": "buildMedias"
    },
    {
      "key": "euandus",
      "title": "欧美剧",
      "url": "https://libvio.site/type/16-${pageNumber}.html",
      "javascript": "buildMedias"
    }
  ],
  "episodes": {
    "javascript": "Episodes"
  },
  "player": {
    "timeout": 20,
    "javascript": "Player"
  },
